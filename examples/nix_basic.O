O^(
let system_info = nix{cap=backend}^(
{
  name = "O-lang Nix bridge";
  answer = 40 + 2;
  packages = [ "python" "html" "nix" ];
}
)_nix{cap=backend}

html^(
<!doctype html>
<html>
  <body>
    <h1>Nix inside O-lang</h1>
    <section>
      $system_info
    </section>
  </body>
</html>
)_html
)_O
