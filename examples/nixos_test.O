#!/usr/bin/env O
# Milestone E — single-machine NixOS test inside an O-lang script.
#
# Run: cargo run -- examples/nixos_test.O
#
# Requirements: Nix with KVM/QEMU (or software emulation).
# The nixos_test^(...)_nixos_test block builds a real NixOS VM, boots it,
# runs the testScript assertions, and returns structured results.

let lab = nixos_test^({
  nodes.machine = { pkgs, ... }: {
    services.nginx.enable = true;
  };

  testScript = ''
    machine.start()
    machine.wait_for_unit("nginx")
    machine.succeed("curl -sf http://localhost | grep -i nginx")
  '';
})_nixos_test

html^(
<!doctype html>
<html>
  <body>
    <h1>NixOS test result</h1>
    <p>Success: $lab</p>
  </body>
</html>
)_html
