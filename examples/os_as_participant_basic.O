#!/usr/bin/env O
# STEP-4: OS-as-participant.
#
# The running operating system becomes a first-class participant in the
# value model. The Nix lattice extends from three rungs to four:
#
#   NixExpr → Derivation → StorePath → System
#               instantiate    realise     activate
#
# A System value REFERS TO something in the world — the live profile —
# rather than carrying a content-addressed snapshot. Equality is by profile
# path, not by current generation. Querying its state requires an
# out-of-band call.
#
# SAFETY: activate($path) always performs dry-activate. A real switch uses
# activate($authority, $path), where the host has explicitly inserted a live,
# profile-scoped system_activation capability into the O scope. No environment
# variable grants that authority.

# (chain commented for cross-platform demo; see original source for full
#  instantiate/realise/activate/current_system example)
#let cfg     = nix_expr^( (import <nixpkgs/nixos> { configuration = ./configuration.nix; }).system )_nix_expr
#let drv     = instantiate($cfg)
#let path    = realise($drv)
#let active  = activate($path) # dry activation
#let switched = activate($authority, $path) # real, host-injected authority
#let here = current_system()

markdown^(
# Step-4 OS-as-participant

- configuration (NixExpr):   `(see source for chain)`
- system derivation (drv):   `(see source)`
- system closure (path):     `(see source)`
- activated profile (System): `(dry activation is unprivileged; real switch requires a live capability)`
- current system reference:  (current_system() builtin)
)_markdown
